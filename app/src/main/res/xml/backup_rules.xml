<?xml version="1.0" encoding="utf-8"?>
<!--
    backup_rules.xml — define qué datos se incluyen en las copias de seguridad
    automáticas de Android (versiones anteriores a Android 12).
    Referenciado en AndroidManifest.xml con android:fullBackupContent.
    NOTA: Este archivo se ignora en dispositivos con API 31+ (Android 12 o superior).
    Para esos dispositivos se usa data_extraction_rules.xml.
    La tablet Honor ELN-W09 tiene Android 13 (API 33) — este archivo no se aplica.
    Está en el proyecto porque Android Studio lo genera automáticamente.
-->
<full-backup-content>
    <!-- Sin reglas: Android hace copia de seguridad de todo por defecto -->
</full-backup-content>