<?xml version="1.0" encoding="utf-8"?>

<!--
    LinearLayout raíz con orientación vertical.
    Estructura en dos partes: ScrollView (contenido) + barra inferior fija.
    La barra inferior queda siempre visible aunque el contenido sea largo.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF">

    <!--
        ScrollView — permite hacer scroll si el contenido no cabe en pantalla.
        layout_height="0dp" + layout_weight="1" → ocupa todo el espacio disponible
        dejando sitio fijo para la barra inferior.
        Solo puede tener UN hijo directo — por eso dentro hay un LinearLayout.
    -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!--
            LinearLayout hijo del ScrollView — contiene todos los campos del formulario.
            padding="24dp" → margen interior en los 4 lados.
        -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Título de la pantalla -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Registrar Ingreso"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="#2C3E50"
                android:layout_marginBottom="24dp"/>

            <!-- Etiqueta del campo fecha -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Fecha"
                android:textSize="16sp"
                android:textColor="#2C3E50"
                android:layout_marginBottom="4dp"/>

            <!--
                Campo fecha — no tiene inputType porque en el Java se desactiva
                la edición manual (setFocusable(false)) y al pulsar abre el DatePickerDialog.
            -->
            <EditText
                android:id="@+id/etFecha"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="48dp"
                android:layout_marginBottom="16dp"/>

            <!-- Etiqueta del campo importe -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Importe (€)"
                android:textSize="16sp"
                android:textColor="#2C3E50"
                android:layout_marginBottom="4dp"/>

            <!--
                Campo importe.
                inputType="numberDecimal" → muestra teclado numérico con punto decimal.
                hint="0.00" → texto gris que desaparece al escribir.
            -->
            <EditText
                android:id="@+id/etImporte"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="0.00"
                android:inputType="numberDecimal"
                android:minHeight="48dp"
                android:layout_marginBottom="24dp"/>

            <!-- Etiqueta tipo de ingreso -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tipo de ingreso"
                android:textSize="16sp"
                android:textColor="#2C3E50"
                android:layout_marginBottom="8dp"/>

            <!--
                LinearLayout horizontal con los dos botones de tipo.
                layout_weight="1" en cada botón → ocupan el mismo ancho.
                backgroundTint="#CCCCCC" → gris por defecto.
                El Java los pone azul (#0288D1) al seleccionarlos.
            -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="24dp"
                android:gravity="center">

                <!--
                    Botón Efectivo.
                    layout_width="0dp" + layout_weight="1" → ocupa la mitad del ancho.
                    layout_marginEnd="8dp" → separación entre los dos botones.
                -->
                <Button
                    android:id="@+id/btnEfectivo"
                    android:layout_width="0dp"
                    android:layout_height="80dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:text="Efectivo"
                    android:textSize="15sp"
                    android:backgroundTint="#CCCCCC"/>

                <!--
                    Botón Tarjeta.
                    layout_marginStart="8dp" → separación entre los dos botones.
                -->
                <Button
                    android:id="@+id/btnTarjeta"
                    android:layout_width="0dp"
                    android:layout_height="80dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:text="Tarjeta"
                    android:textSize="15sp"
                    android:backgroundTint="#CCCCCC"/>

            </LinearLayout>

            <!-- Etiqueta notas -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Notas"
                android:textSize="16sp"
                android:textColor="#2C3E50"
                android:layout_marginBottom="4dp"/>

            <!-- Campo notas opcional -->
            <EditText
                android:id="@+id/etNotas"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Notas opcionales"
                android:inputType="text"
                android:minHeight="48dp"
                android:layout_marginBottom="24dp"/>

            <!--
                Botón guardar ingreso.
                minHeight="64dp" → altura generosa para tablet.
            -->
            <Button
                android:id="@+id/btnGuardarIngreso"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Guardar Ingreso"
                android:textSize="18sp"
                android:minHeight="64dp"
                android:layout_marginBottom="8dp"/>

            <!--
                Mensaje de confirmación o error.
                visibility="gone" → invisible y sin espacio hasta que el Java lo muestre.
                El color se cambia desde Java: verde para éxito, rojo para error.
            -->
            <TextView
                android:id="@+id/tvMensaje"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:visibility="gone"/>

        </LinearLayout>
    </ScrollView>

    <!--
        Barra inferior de navegación — FIJA, fuera del ScrollView.
        layout_height="64dp" → altura fija siempre visible.
        background="#F0F0F0" → fondo gris claro para diferenciarla del contenido.
        Los dos botones usan layout_weight="1" para repartir el ancho a partes iguales.
    -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:background="#F0F0F0"
        android:gravity="center">

        <!--
            Icono casita → navega a MenuActivity.
            ic_menu_compass → icono incluido en Android.
            selectableItemBackgroundBorderless → efecto ripple sin borde.
            scaleType="center" → el icono no se estira, se centra.
        -->
        <ImageButton
            android:id="@+id/iconoHome"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:src="@android:drawable/ic_menu_compass"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Ir al menú principal"
            android:scaleType="center"/>

        <!-- Icono informes → navega a InformesActivity -->
        <ImageButton
            android:id="@+id/iconoInformes"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:src="@android:drawable/ic_menu_sort_by_size"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Ir a informes"
            android:scaleType="center"/>

    </LinearLayout>

</LinearLayout>