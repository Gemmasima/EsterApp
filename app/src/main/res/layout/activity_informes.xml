<?xml version="1.0" encoding="utf-8"?>

<!--
    LinearLayout raíz vertical.
    Estructura: ScrollView (spinners + totales) + título fijo + ListView + botón CSV + barra inferior.
    El ListView está FUERA del ScrollView — esto es importante porque un ListView dentro
    de un ScrollView no sabe cuánto espacio tiene y no muestra todos los elementos.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF">

    <!--
        ScrollView solo para la parte superior: spinners y bloque de totales.
        layout_height="wrap_content" → solo ocupa lo que necesita, no más.
    -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Título de la pantalla -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Informes"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="#2C3E50"
                android:layout_marginBottom="24dp"/>

            <!--
                Fila horizontal con dos columnas: spinner Año y spinner Mes.
                Cada columna usa layout_weight="1" para ocupar la mitad del ancho.
            -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="24dp">

                <!-- Columna izquierda: spinner Año -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginEnd="8dp">

                    <TextView android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Año" android:textSize="14sp"
                        android:textColor="#2C3E50" android:layout_marginBottom="4dp"/>

                    <!-- El Java carga los últimos 5 años en este spinner -->
                    <Spinner android:id="@+id/spinnerAnio"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="48dp"/>

                </LinearLayout>

                <!-- Columna derecha: spinner Mes -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="8dp">

                    <TextView android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Mes" android:textSize="14sp"
                        android:textColor="#2C3E50" android:layout_marginBottom="4dp"/>

                    <!-- El Java carga Enero...Diciembre y selecciona el mes actual -->
                    <Spinner android:id="@+id/spinnerMes"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="48dp"/>

                </LinearLayout>

            </LinearLayout>

            <!--
                Bloque de totales con fondo gris claro.
                Muestra Ingresos (verde), Gastos (rojo) y Balance.
                Los valores los actualiza el Java con actualizarTotales().
            -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#F8F8F8"
                android:padding="16dp">

                <!-- Fila Ingresos -->
                <LinearLayout android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Ingresos"
                        android:textSize="16sp" android:textColor="#2C3E50"/>
                    <!-- El Java actualiza este valor en verde -->
                    <TextView android:id="@+id/tvTotalIngresos"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="+0,00 €" android:textSize="16sp"
                        android:textColor="#27AE60" android:textStyle="bold"/>
                </LinearLayout>

                <!-- Fila Gastos -->
                <LinearLayout android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Gastos"
                        android:textSize="16sp" android:textColor="#2C3E50"/>
                    <!-- El Java actualiza este valor en rojo -->
                    <TextView android:id="@+id/tvTotalGastos"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="-0,00 €" android:textSize="16sp"
                        android:textColor="#E74C3C" android:textStyle="bold"/>
                </LinearLayout>

                <!-- Línea separadora -->
                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="#DDDDDD" android:layout_marginBottom="12dp"/>

                <!-- Fila Balance -->
                <LinearLayout android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Balance"
                        android:textSize="18sp" android:textStyle="bold"
                        android:textColor="#2C3E50"/>
                    <!-- El Java lo pone verde si positivo, rojo si negativo -->
                    <TextView android:id="@+id/tvBalance"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="0,00 €" android:textSize="18sp"
                        android:textStyle="bold" android:textColor="#27AE60"/>
                </LinearLayout>

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!--
        Título "Últimos movimientos" — FUERA del ScrollView.
        Queda fijo entre el bloque de totales y la lista.
    -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Últimos movimientos"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#2C3E50"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="16dp"
        android:paddingBottom="8dp"/>

    <!--
        ListView de movimientos — FUERA del ScrollView.
        layout_height="0dp" + layout_weight="1" → ocupa todo el espacio restante.
        Si estuviera dentro del ScrollView no mostraría todos los elementos correctamente
        porque el ScrollView no le daría altura definida.
        dividerHeight="0.5dp" → línea fina entre movimientos.
        El Java rellena este ListView con el adaptador personalizado de mostrarListaMovimientos().
    -->
    <ListView
        android:id="@+id/listViewMovimientos"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:divider="@android:color/darker_gray"
        android:dividerHeight="0.5dp"/>

    <!--
        Botón Generar informe — visibility="gone" por defecto.
        El Java lo muestra solo para Administrador y Gerente.
        Trabajador nunca lo ve.
    -->
    <Button
        android:id="@+id/btnGenerarCSV"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Generar informe"
        android:textSize="18sp"
        android:minHeight="64dp"
        android:visibility="gone"/>

    <!-- Barra inferior de navegación — fija -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:background="#F0F0F0"
        android:gravity="center">

        <ImageButton android:id="@+id/iconoHome"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1"
            android:src="@android:drawable/ic_menu_compass"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Ir al menú principal"
            android:scaleType="center"/>

        <ImageButton android:id="@+id/iconoInformes"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1"
            android:src="@android:drawable/ic_menu_sort_by_size"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Ir a informes"
            android:scaleType="center"/>

    </LinearLayout>

</LinearLayout>